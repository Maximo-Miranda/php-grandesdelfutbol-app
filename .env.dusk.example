# Configuración para los tests E2E con Laravel Dusk.
# Copiá este archivo como .env.dusk.local y completá los valores marcados.
#
# Setup completo:
#   1) cp .env.dusk.example .env.dusk.local
#   2) Generá una APP_KEY: php artisan key:generate --show
#   3) Pegá el valor en APP_KEY abajo
#   4) Creá la BD: createdb -h 127.0.0.1 -U sail grandesdelfutbol_dusk
#   5) Migrá (flag oficial --env, carga este archivo): php artisan migrate --env=dusk.local
#   6) Corré: composer dusk

APP_NAME="Grandes del Futbol"
APP_ENV=dusk
APP_KEY=                                      # ← generar con: php artisan key:generate --show
APP_DEBUG=true
APP_URL=http://localhost:8001                 # ← puerto reservado para Dusk (NO usar 8000)

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=4                               # ← rondas bajas: hash rápido en tests

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Postgres aislado para Dusk — NO compartir con la BD de desarrollo
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=grandesdelfutbol_dusk
DB_USERNAME=sail
DB_PASSWORD=password

# Drivers neutros: nada que requiera servicios externos
SESSION_DRIVER=file
SESSION_SECURE_COOKIE=false
QUEUE_CONNECTION=sync
CACHE_STORE=array
SCOUT_DRIVER=collection
MAIL_MAILER=array
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Apagar plugins de observabilidad para no contaminar tests
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
